<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <ReportParameters>
    <ReportParameter Name="ParamSigla">
      <DataType>String</DataType>
      <AllowBlank>true</AllowBlank>
      <DefaultValue><Values><Value></Value></Values></DefaultValue>
      <Prompt>Sigla de Materia</Prompt>
    </ReportParameter>
  </ReportParameters>
  <DataSources>
    <DataSource Name="dsAsistencia">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString />
      </ConnectionProperties>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsAsistencia">
      <Fields>
        <Field Name="sigla"><DataField>sigla</DataField></Field>
        <Field Name="materia"><DataField>materia</DataField></Field>
        <Field Name="dia_semana"><DataField>dia_semana</DataField></Field>
        <Field Name="hora_inicio"><DataField>hora_inicio</DataField></Field>
        <Field Name="hora_fin"><DataField>hora_fin</DataField></Field>
        <Field Name="fecha_asistencia"><DataField>fecha_asistencia</DataField></Field>
        <Field Name="aula"><DataField>aula</DataField></Field>
        <Field Name="docente"><DataField>docente</DataField></Field>
      </Fields>
      <Query><DataSourceName>dsAsistencia</DataSourceName><CommandText /></Query>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="Titulo">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>Asistencia por Materia — UniversidadXYZ</Value>
                    <Style><FontSize>14pt</FontSize><FontWeight>Bold</FontWeight></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.1in</Top><Left>0in</Left><Height>0.4in</Height><Width>7.5in</Width>
          </Textbox>
          <Textbox Name="SubTitulo">
            <CanGrow>true</CanGrow>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>=("Materia: " &amp; Parameters!ParamSigla.Value)</Value>
                    <Style><FontSize>9pt</FontSize><Color>Gray</Color></Style>
                  </TextRun>
                </TextRuns>
                <Style><TextAlign>Center</TextAlign></Style>
              </Paragraph>
            </Paragraphs>
            <Top>0.55in</Top><Left>0in</Left><Height>0.25in</Height><Width>7.5in</Width>
          </Textbox>
          <Tablix Name="TblAsistencia">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>1.1in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>0.9in</Width></TablixColumn>
                <TablixColumn><Width>0.7in</Width></TablixColumn>
                <TablixColumn><Width>2in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>
                <TablixRow>
                  <Height>0.25in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="h1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Fecha</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>SteelBlue</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Día</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>SteelBlue</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Inicio</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>SteelBlue</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Fin</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>SteelBlue</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Aula</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>SteelBlue</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="h6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>Docente</Value><Style><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns></Paragraph></Paragraphs><Style><BackgroundColor>SteelBlue</BackgroundColor></Style></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
                <TablixRow>
                  <Height>0.22in</Height>
                  <TablixCells>
                    <TablixCell><CellContents><Textbox Name="d1"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Format(Fields!fecha_asistencia.Value,"dd/MM/yyyy")</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="d2"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!dia_semana.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="d3"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!hora_inicio.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="d4"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!hora_fin.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="d5"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!aula.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                    <TablixCell><CellContents><Textbox Name="d6"><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!docente.Value</Value></TextRun></TextRuns></Paragraph></Paragraphs></Textbox></CellContents></TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember>
                <TablixMember><Group Name="Details" /></TablixMember>
              </TablixMembers>
            </TablixRowHierarchy>
            <DataSetName>dsAsistencia</DataSetName>
            <Top>0.9in</Top><Left>0in</Left><Height>0.47in</Height><Width>7.5in</Width>
          </Tablix>
        </ReportItems>
        <Height>2in</Height>
      </Body>
      <Width>7.5in</Width>
      <Page>
        <PageHeight>11in</PageHeight>
        <PageWidth>8.5in</PageWidth>
        <LeftMargin>0.5in</LeftMargin>
        <RightMargin>0.5in</RightMargin>
        <TopMargin>0.5in</TopMargin>
        <BottomMargin>0.5in</BottomMargin>
      </Page>
    </ReportSection>
  </ReportSections>
  <Language>es-BO</Language>
</Report>
